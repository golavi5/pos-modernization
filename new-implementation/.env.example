# Root compose env — MySQL container credentials, referenced by docker-compose.yml
# (${MYSQL_*}) for the local `mysql` service.
#
# Setup:  cp .env.example .env   then set strong local values.
# `.env` is gitignored — NEVER commit real secrets. Production MySQL credentials
# live in the Coolify-managed database, not here (see DEPLOYMENT-COOLIFY.md).
#
# Note: backend DB_PASSWORD (backend/.env) must match MYSQL_PASSWORD below.
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD
MYSQL_DATABASE=pos_db
MYSQL_USER=pos_user
MYSQL_PASSWORD=CHANGE_ME_STRONG_PASSWORD
