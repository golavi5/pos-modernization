# M4 migration CLI — copy to .env and fill for a real run.
# Write commands (reset, import) REFUSE to run unless NODE_ENV=migration AND
# TARGET_DB_NAME ends in `_migration`. These guards protect the live DB.
NODE_ENV=migration

# Legacy source DB (the frozen dump) — compose `mysql_legacy` on :3309.
LEGACY_DB_HOST=localhost
LEGACY_DB_PORT=3309
LEGACY_DB_USER=root
LEGACY_DB_PASSWORD=legacy_root
LEGACY_DB_NAME=pos_legacy

# Migration target DB — same MySQL server as live pos_db (:3308), separate DB.
# Name MUST end in `_migration`.
TARGET_DB_HOST=localhost
TARGET_DB_PORT=3308
TARGET_DB_USER=root
TARGET_DB_PASSWORD=
TARGET_DB_NAME=pos_db_migration

# Target tenant the single-tenant legacy rows are assigned to (provisioned
# company UUID). Defaults to a fixed dev UUID.
# MIGRATION_COMPANY_ID=00000000-0000-4000-8000-000000000001
