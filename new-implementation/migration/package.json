{
  "name": "@pos/migration",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "M4 legacy-migration parity-validation CLI (POS-MIGR-001)",
  "bin": {
    "migrate": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "migrate": "tsx src/cli.ts",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '**/*.e2e.spec.ts'",
    "test:e2e": "vitest run tests/e2e.spec.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "mysql2": "^3.11.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testcontainers/mysql": "^10.13.0",
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.8",
    "testcontainers": "^10.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.0"
  }
}
